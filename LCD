ORG 0000H

MOV A,#38H
ACALL C
MOV A,#0EH
ACALL C
MOV A,#01H
ACALL C
MOV A,#06H
ACALL C

MOV DPTR,#M

L: CLR A
MOVC A,@A+DPTR
JZ $
ACALL D
INC DPTR
SJMP L

C: MOV P1,A
CLR P2.0
CLR P2.1
SETB P2.2
ACALL DL
CLR P2.2
RET

D: MOV P1,A
SETB P2.0
CLR P2.1
SETB P2.2
ACALL DL
CLR P2.2
RET

DL: MOV R7,#100
DJNZ R7,$
RET

M: DB 'HI',0

END
